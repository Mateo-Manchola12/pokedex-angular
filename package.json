{
  "name": "pokedex-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:mobile": "ng build && npx cap sync",
    "watch": "ng build --watch --configuration development",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint . --cache --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run typecheck && npm run format:check",
    "precommit": "npm run check",
    "test": "ng test"
  },
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "~21.2.7",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/material": "~21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/router": "^21.2.7",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.7",
    "@angular/material": "^21.2.7",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.12",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.8"
  }
}
